    "sources": {
      "official": "Cisco Technical Content Style Guide (stylegd.pdf, August 2022)",
      "observed": "Editor comments from masperli and jlauterb-edit",
      "emerging": "New acronyms flagged during review - require verification",
      "gap_analysis": "Feature 014 gap analysis from 7 test courses (2026-02-27)"
