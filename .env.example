# LWC Editorial Integration Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Required for AI-Powered Editorial Review (AWS Bedrock)
# =============================================================================

# AWS credentials for Bedrock
# Get from: AWS Console > IAM > Users > Security credentials
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-2

# Optional: Custom Bedrock model ID (default: us.anthropic.claude-3-5-sonnet-20241022-v2:0)
# Use inference profile IDs for cross-region inference
# BEDROCK_MODEL_ID=us.anthropic.claude-3-5-sonnet-20241022-v2:0

# =============================================================================
# Optional: Jira Integration (for User Story 3)
# =============================================================================

# Jira credentials for cisco-learning.atlassian.net
JIRA_EMAIL=your_email@cisco.com
JIRA_API_TOKEN=your_jira_api_token_here

# =============================================================================
# Optional: Direct Anthropic API (fallback if Bedrock unavailable)
# =============================================================================

# ANTHROPIC_API_KEY=your_anthropic_api_key_here
